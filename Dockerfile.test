# Test image for the Linux half of the install Makefile.
# Scope: stow placement (`make dotfiles`).
# Out of scope: pacman / aur (Arch-only) and brew / bundle (macOS-only).
# Languages (mise install) is opt-in via `make docker-test-languages` to keep
# the default test fast.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        bash ca-certificates curl git make stow \
    && rm -rf /var/lib/apt/lists/*

ARG USER=tester
ARG UID=1000
ARG GID=1000
RUN groupadd -g ${GID} ${USER} \
 && useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USER}

USER ${USER}
WORKDIR /home/${USER}/dotfiles
