#!/usr/bin/env bash
set -euo pipefail

EXPLICIT_NAME="${1:-}"
SESSION="${EXPLICIT_NAME:-dev}"
DIR="${2:-$PWD}"

if [ -n "${TMUX:-}" ]; then
  echo "already inside tmux" >&2
  exit 1
fi

if [ -n "$EXPLICIT_NAME" ]; then
  # Explicit name: attach to the existing session if any.
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach -t "$SESSION"
  fi
else
  # No name given: always start a new session by finding a free suffix.
  i=2
  while tmux has-session -t "$SESSION" 2>/dev/null; do
    SESSION="dev-${i}"
    i=$((i + 1))
  done
fi

TL=$(tmux new-session  -d -s "$SESSION" -c "$DIR" -P -F '#{pane_id}')
R=$( tmux split-window -h -t "$TL"      -c "$DIR" -P -F '#{pane_id}')
BL=$(tmux split-window -v -t "$TL"      -c "$DIR" -P -F '#{pane_id}')

tmux send-keys -t "$TL" 'claude' Enter
tmux send-keys -t "$R"  'es .'   Enter
: "$BL"

tmux select-pane -t "$TL"
exec tmux attach -t "$SESSION"
